        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#9ece6a", "value": null }, { "color": "#e0af68", "value": 1 }, { "color": "#f7768e", "value": 5 }] },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Geçersiz" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f7768e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Geçerli" },  "properties": [{ "id": "color", "value": { "fixedColor": "#9ece6a", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 21 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "🧬 FITS Validasyon",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "dag_fits_valid_total",   "instant": true, "legendFormat": "Geçerli",  "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "dag_fits_invalid_total", "instant": true, "legendFormat": "Geçersiz", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
