          "thresholds": { "mode": "absolute", "steps": [{ "color": "#9ece6a", "value": null }, { "color": "#e0af68", "value": 50 }, { "color": "#f7768e", "value": 100 }] },
          "unit": "short"
        },
        "overrides": []
