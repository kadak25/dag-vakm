    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "gradientMode": "none", "lineWidth": 1 },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#7aa2f7", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 21 },
      "id": 40,
      "options": { "barRadius": 0.1, "barWidth": 0.7, "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "orientation": "horizontal", "showValue": "always", "stacking": "none", "tooltip": { "mode": "single" } },
      "title": "🌟 Top Observed Targets",
